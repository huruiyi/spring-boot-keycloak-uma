  }, {
    "name" : "perm-order-delete",
    "resource" : "order",
    "scope" : "delete",
    "policy" : "policy-admin"
  }, {
    "name" : "perm-user-view",
    "resource" : "user",
    "scope" : "view",
    "policy" : "policy-manager"
  }, {
    "name" : "perm-user-create",
    "resource" : "user",
    "scope" : "create",
    "policy" : "policy-admin"
  }, {
    "name" : "perm-user-edit",
    "resource" : "user",
    "scope" : "edit",
    "policy" : "policy-admin"
  }, {
    "name" : "perm-user-delete",
    "resource" : "user",
    "scope" : "delete",
