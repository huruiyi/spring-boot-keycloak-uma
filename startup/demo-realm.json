{
  "realm": "demo",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "系统管理员"
      },
      {
        "name": "manager",
        "description": "业务管理员"
      },
      {
        "name": "user",
        "description": "普通用户"
      },
      {
        "name": "auditor",
        "description": "审计人员"
      }
    ]
  },
  "clients": [
    {
      "clientId": "demo-frontend",
      "name": "演示前端",
      "description": "前端登录客户端，负责用户登录和按需申请 UMA RPT",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "rootUrl": "http://localhost:5173",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:8081/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8081"
      ],
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "demo-api",
      "name": "演示 API 资源服务器",
      "description": "UMA 资源服务器，承载 Resource、Scope、Policy、Permission 并作为运行时授权执行源",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "demo-api-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [],
      "attributes": {
        "uma.model-source": "keycloak"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "firstName": "系统",
      "lastName": "管理员",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "manager",
        "user"
      ]
    },
    {
      "username": "manager",
      "enabled": true,
      "email": "manager@example.com",
      "firstName": "部门",
      "lastName": "经理",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "manager123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "manager",
        "user"
      ]
    },
    {
      "username": "staff",
      "enabled": true,
      "email": "staff@example.com",
      "firstName": "普通",
      "lastName": "员工",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "staff123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "auditor",
      "enabled": true,
      "email": "auditor@example.com",
      "firstName": "审计",
      "lastName": "人员",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "auditor123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "auditor",
        "user"
      ]
    }
  ]
}
